# ============================================================
# 自社サーバー用 環境変数サンプル
# cp .env.example .env  して実際の値を設定してください
# ============================================================

# --- MariaDB (docker-compose) ---
DB_ROOT_PASSWORD=change-me-root
DB_NAME=juchou
DB_USER=juchou
DB_PASSWORD=change-me-db

# --- アプリケーション ---
DATABASE_URL=mysql://juchou:change-me-db@db:3306/juchou
JWT_SECRET=change-me-to-64-random-chars

PORT=3000

# --- LLM API (OpenAI / Azure OpenAI / 互換API) ---
# BUILT_IN_FORGE_API_URL: OpenAI互換エンドポイントのベースURL
BUILT_IN_FORGE_API_URL=https://api.openai.com
BUILT_IN_FORGE_API_KEY=sk-...

# --- オブジェクトストレージ (Cloudflare R2 / AWS S3 / MinIO) ---
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=juchou-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_FORCE_PATH_STYLE=false
S3_SIGNED_URL_TTL_SEC=3600

# --- Docker イメージ名 (docker-compose app.image) ---
APP_IMAGE=ghcr.io/allblacks619/juchou-group.masterfile:latest

# --- フロントエンドビルド引数 (Dockerイメージビルド時) ---
VITE_APP_ID=juchou

# --- 初期オーナー作成 (scripts/seed-owner.mjs 用) ---
OWNER_LOGIN_ID=admin
OWNER_PASSWORD=change-me-password
OWNER_OPEN_ID=owner_admin
OWNER_NAME=管理者

# --- Cloudflare Tunnel (任意・profiles: tunnel) ---
CLOUDFLARE_TUNNEL_TOKEN=

# ============================================================
# 以下の変数は MANUS プラットフォーム専用です。
# 自社サーバーでは設定不要です。
# ============================================================
# OAUTH_SERVER_URL=         # MANUS OAuth サーバー URL (不要)
# VITE_OAUTH_PORTAL_URL=   # MANUS ログインポータル URL (不要)
# OWNER_OPEN_ID=           # MANUS ユーザー openId (seed-owner で代替)
